{
  "name": "sp-dashboard",
  "version": "1.0.1",
  "description": "A visual dashboard plugin providing metrics, charts, and daily summaries of your tasks and tracked time.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:min": "./scripts/minify.sh sp-dashboard",
    "check:syntax": "node scripts/check-js.js",
    "screenshot": "node scripts/screenshot.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "html-minifier-terser": "^6.1.0",
    "jsdom": "^23.0.0",
    "puppeteer": "^24.37.5",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "super-productivity",
    "plugin",
    "dashboard"
  ],
  "author": "Super Productivity Community",
  "license": "MIT",
  "dependencies": {
    "acorn": "^8.16.0"
  }
}
